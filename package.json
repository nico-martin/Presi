    "@types/node": "^20.8.9",
    "@types/postcss-mixins": "^9.0.2",
    "@types/react": "^18.2.33",
    "@types/react-dom": "^18.2.14",
    "autoprefixer": "^10.4.16",
    "dotenv": "^16.3.1",
    "esbuild": "^0.25.5",
    "postcss-mixins": "^9.0.4",
    "postcss-nested": "^6.0.1",
    "postcss-preset-env": "^9.2.0",
